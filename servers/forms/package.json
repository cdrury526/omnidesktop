{
  "name": "@omni/forms-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Generic, schema-driven interactive-forms MCP App server for Omni Desktop.",
  "scripts": {
    "build": "cross-env INPUT=mcp-app.html vite build",
    "serve": "bun main.ts",
    "dev": "concurrently -k \"cross-env INPUT=mcp-app.html vite build --watch\" \"bun --watch main.ts\"",
    "start": "cross-env INPUT=mcp-app.html vite build && bun main.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@omni/forms-dsl": "workspace:*",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vite-plugin-singlefile": "^2.3.0"
  }
}
